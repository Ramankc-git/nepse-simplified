generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  active       Boolean  @default(true)
  subscribedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model NewsletterView {
  id       String   @id @default(cuid())
  slug     String
  ip       String   @default("")
  viewedAt DateTime @default(now())

  @@index([slug])
  @@index([viewedAt])
}

model PageView {
  id       String   @id @default(cuid())
  path     String
  ip       String   @default("")
  viewedAt DateTime @default(now())

  @@index([path])
  @@index([viewedAt])
}
